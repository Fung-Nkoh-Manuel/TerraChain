RewriteEngine On
RewriteBase /terrachain-v2/

# Route API requests FIRST (before file/directory check)
RewriteRule ^public/api/(.*)$ api/router.php [QSA,L]
RewriteRule ^api/(.*)$ api/router.php [QSA,L]

# Don't rewrite if file or directory exists
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Route everything else to public
RewriteRule ^(.*)$ public/$1 [L]