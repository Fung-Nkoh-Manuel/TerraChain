{
  "info": {
    "name": "TerraChain API - Authentication Testing on xampp",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost/terrachain-v2/public//api"
    },
    {
      "key": "userId",
      "value": ""
    },
    {
      "key": "otpCode",
      "value": "123456"
    },
    {
      "key": "sessionCookie",
      "value": ""
    },
    {
      "key": "testUsername",
      "value": ""
    },
    {
      "key": "testPassword",
      "value": "123456"
    },
    {
      "key": "testEmail",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "1. User Registration",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();",
              "",
              "pm.test(\"Status code is 200\", function() {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Registration successful\", function() {",
              "    pm.expect(jsonData.success).to.be.true;",
              "});",
              "",
              "if (jsonData.success) {",
              "    var requestBody = JSON.parse(pm.request.body.raw);",
              "    pm.collectionVariables.set('testUsername', requestBody.username);",
              "    pm.collectionVariables.set('testPassword', requestBody.password);",
              "    pm.collectionVariables.set('testEmail', requestBody.email);",
              "    console.log('Saved:', requestBody.username);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "url": "{{baseUrl}}/auth/register",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"username\": \"testuser_{{$timestamp}}\",\n    \"email\": \"test{{$timestamp}}@example.com\",\n    \"password\": \"123456\",\n    \"full_name\": \"Test User\",\n    \"phone\": \"+237600000000\",\n    \"national_id\": \"CM{{$randomInt}}\"\n}"
        }
      }
    },
    {
      "name": "2. Login (Request OTP)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();",
              "",
              "pm.test(\"Status code is 200\", function() {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Login successful - OTP sent\", function() {",
              "    pm.expect(jsonData.success).to.be.true;",
              "});",
              "",
              "if (jsonData.success && jsonData.data && jsonData.data.user_id) {",
              "    pm.collectionVariables.set('userId', jsonData.data.user_id);",
              "    console.log('User ID:', jsonData.data.user_id);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "url": "{{baseUrl}}/auth/login",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"username\": \"{{testUsername}}\",\n    \"password\": \"{{testPassword}}\"\n}"
        }
      }
    },
    {
      "name": "3. Verify OTP (Complete Login)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();",
              "",
              "pm.test(\"Status code is 200\", function() {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"OTP verification successful\", function() {",
              "    pm.expect(jsonData.success).to.be.true;",
              "});",
              "",
              "var cookies = pm.cookies.toObject();",
              "",
              "if (cookies.PHPSESSID) {",
              "    pm.collectionVariables.set('sessionCookie', cookies.PHPSESSID);",
              "    console.log('Session saved:', cookies.PHPSESSID);",
              "} else if (pm.response.headers.has('Set-Cookie')) {",
              "    var setCookie = pm.response.headers.get('Set-Cookie');",
              "    var match = setCookie.match(/PHPSESSID=([^;]+)/);",
              "    if (match) {",
              "        pm.collectionVariables.set('sessionCookie', match[1]);",
              "        console.log('Session from header:', match[1]);",
              "    }",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "url": "{{baseUrl}}/auth/verify-otp",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"user_id\": {{userId}},\n    \"otp\": \"{{otpCode}}\"\n}"
        }
      }
    },
    {
      "name": "4. Get Authenticated User (Me)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();",
              "",
              "pm.test(\"Status code is 200\", function() {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Authenticated request successful\", function() {",
              "    pm.expect(jsonData.success).to.be.true;",
              "});",
              ""
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/auth/me",
        "header": [
          {
            "key": "Cookie",
            "value": "PHPSESSID={{sessionCookie}}"
          }
        ]
      }
    },
    {
      "name": "5. Forgot Password Request",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();",
              "",
              "pm.test(\"Status code is 200\", function() {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Password reset request sent\", function() {",
              "    pm.expect(jsonData.success).to.be.true;",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "url": "{{baseUrl}}/auth/forgot-password",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"email\": \"{{testEmail}}\"\n}"
        }
      }
    },
    {
      "name": "6. Logout (Destroy Session)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();",
              "",
              "pm.test(\"Status code is 200\", function() {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Logout successful\", function() {",
              "    pm.expect(jsonData.success).to.be.true;",
              "});",
              "",
              "console.log('Session destroyed');"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "url": "{{baseUrl}}/auth/logout",
        "header": [
          {
            "key": "Cookie",
            "value": "PHPSESSID={{sessionCookie}}"
          }
        ]
      }
    },
    {
      "name": "7. Verify Session Expired (Should Return 401)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Session expired - returns 401\", function() {",
              "    pm.expect(pm.response.code).to.equal(401);",
              "});",
              "",
              "console.log('Session correctly invalidated');"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/auth/me",
        "header": [
          {
            "key": "Cookie",
            "value": "PHPSESSID={{sessionCookie}}"
          }
        ]
      }
    }
  ]
}